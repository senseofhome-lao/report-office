{
  "hosting": {
    "public": "public",
    "ignore": ["**/.*", "**/*.md"],
    "rewrites": [
      {
        "source": "/api/**",
        "run": { "serviceId": "api", "region": "us-central1" }
      },
      { "source": "/user", "destination": "/user/dashboard.html" },
      { "source": "/admin", "destination": "/admin/dashboard.html" }
    ]
  },
  "functions": [
    {
      "source": ".",
      "codebase": "default",
      "runtime": "nodejs22",
      "ignore": [
        "node_modules/**",
        "public/**",
        "uploads/**",
        ".git/**",
        "*.md"
      ]
    }
  ]
}
